# worktree 作成先のベースディレクトリ
GIT_WORKTREE_PATH=~/.worktree-deck/worktrees
# Codex のホームディレクトリ
CODEX_HOME=~/.codex
# worktree-deck のセッション検索日数
WORKTREE_DECK_SEARCH_DAYS=30
# working を done 扱いにする経過日数
WORKTREE_DECK_DONE_THRESHOLD_DAYS=1
# worktree-deck の storage 保存先
WORKTREE_DECK_STORAGE_DIR=~/.worktree-deck/storage
